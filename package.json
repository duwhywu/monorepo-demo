{
  "name": "monorepo-demo",
  "private": true,
  "scripts": {
    "build:shared": "pnpm --filter shared build",
    "build:app-a": "pnpm --filter app-a build",
    "build:app-b": "pnpm --filter app-b build",
    "build:all": "pnpm -r build",
    "dev:app-a": "pnpm --filter app-a dev",
    "dev:app-b": "pnpm --filter app-b dev"
  },
  "engines": {
    "node": ">=18"
  }
}
